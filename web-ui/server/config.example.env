# Web UI LAN HTTPS endpoint.
RAYME_WEB_BIND_HOST=192.168.1.199
RAYME_WEB_PORT=8443
RAYME_WEB_PUBLIC_URL=https://192.168.1.199:8443

# TLS files generated with mkcert for rayme.local and 192.168.1.199.
RAYME_TLS_CERT=.certs/rayme.local+1.pem
RAYME_TLS_KEY=.certs/rayme.local+1-key.pem

# Explicit browser origins. Do not use a wildcard origin for app APIs.
RAYME_ALLOWED_ORIGINS=https://192.168.1.199:8443

# Phase 1 AI backend health endpoint.
RAYME_AI_BACKEND_BASE_URL=https://192.168.1.199:9443

# External OpenAI-compatible LLM endpoint. Keep the key server-side.
RAYME_LLM_BASE_URL=https://api.openai.com/v1
RAYME_LLM_API_KEY=
RAYME_LLM_MODEL=gpt-4.1-mini
